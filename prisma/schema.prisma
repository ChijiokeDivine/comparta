// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum KybStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum Chain {
  ARC_TESTNET
  ARC_MAINNET
  ETH_SEPOLIA
  ETH_MAINNET
  SOLANA
  BASE
  AVAX
  ARBITRUM
}

enum LedgerAccountType {
  OPERATING
  RESERVE
  PAYROLL
  SAVINGS
  CUSTOM
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

// YIELD_DEPLOYMENT / YIELD_REDEMPTION added for Phase 7 (Smart Savings) —
// see lib/savings/yield.ts. Every other value predates that phase.
enum LedgerReferenceType {
  ONCHAIN_TX
  INTERNAL_TRANSFER
  INVOICE
  PAYROLL_RUN
  SAVINGS_SWEEP
  DCA
  ADJUSTMENT
  ALLOCATION_RULE
  YIELD_DEPLOYMENT
  YIELD_REDEMPTION
}

enum OnchainDirection {
  IN
  OUT
}

enum OnchainTxStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum IdentifierType {
  USERNAME
  ADDRESS
}

enum IdempotencyKeyStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AllocationRuleType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum AllocationTrigger {
  ON_INCOMING_PAYMENT
  SCHEDULED
}

enum AllocationExecutionStatus {
  EXECUTED
  SKIPPED_ZERO_AMOUNT
  FAILED
}

// Phase 6 — Payroll
enum PayType {
  SALARY
  HOURLY
  CONTRACT
}

enum PayrollFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PayrollRunStatus {
  DRAFT
  PENDING_APPROVAL
  PROCESSING
  COMPLETED
  FAILED
}

enum PayrollRunItemStatus {
  PENDING
  SENT
  CONFIRMED
  FAILED
}

// Phase 3 — Invoicing
enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  VOID
}

enum InvoiceEventType {
  CREATED
  SENT
  VIEWED
  REMINDER_SENT
  PAID
  VOID
}

// USDC is the only currency actually settled today. EURC is modeled now
// so the column/type exists, but invoice creation rejects anything other
// than USDC until Phase 4 FX lands (see lib/invoices/service.ts).
enum InvoiceCurrency {
  USDC
  EURC
}

// Phase 4 — Payment Links
enum PaymentLinkType {
  FIXED_AMOUNT
  OPEN_AMOUNT
}

enum PaymentLinkStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

// Lifecycle of a single checkout attempt (one PaymentLinkPayment row per
// attempt — a payer who abandons and retries gets a fresh row, not a
// reused one, so history is a truthful append-only log of attempts).
enum PaymentLinkPaymentStatus {
  PENDING            // checkout session opened, funds not yet observed
  CONFIRMED          // funds received and the ledger was credited
  FAILED             // card/ACH declined, or the wallet tx itself failed onchain
  WRONG_AMOUNT_REFUNDED // wallet path only: payer sent an amount that didn't
  // match any open session on a FIXED_AMOUNT link; funds were credited then
  // immediately refunded onchain rather than silently accepted — see
  // lib/paymentLinks/reconciliation.ts.
}

enum PaymentMethod {
  WALLET
  CARD
}

// Phase 7 — Smart Savings (yield)
enum YieldPositionStatus {
  ACTIVE
  REDEEMED
}

enum SavingsRuleTrigger {
  PERCENTAGE_OF_INCOME
  ROUND_UP
  FIXED_RECURRING
}

enum SavingsRuleExecutionStatus {
  EXECUTED
  SKIPPED_ZERO_AMOUNT
  SKIPPED_FLOOR_PROTECTED
  FAILED
}

enum YieldRedemptionStatus {
  PENDING     // request created, not yet submitted to Circle
  PROCESSING  // submitted to Circle, awaiting settlement confirmation
  COMPLETED   // USDC credited back to the bucket's liquid balance
  FAILED
}

// Phase 8 — DCA / Recurring Transfers
enum RecurringTransferFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum RecurringTransferStatus {
  ACTIVE
  PAUSED
  CANCELLED  // user-initiated stop
  COMPLETED  // reached its endDate — a terminal state distinct from CANCELLED
}

enum RecurringTransferExecutionStatus {
  PENDING
  SUCCESS
  FAILED_INSUFFICIENT_FUNDS
  FAILED_OTHER
}

// Phase 9 — Spending Insights
enum TransactionCategoryKind {
  SYSTEM // one of the curated 7, seeded per-org — see lib/insights/categorization/seed.ts
  CUSTOM // org-defined
}

enum CategorizationSource {
  RULE   // deterministic referenceType -> category mapping, no LLM call
  LLM    // LLM-suggested (may still be pending confirmation — see needsConfirmation)
  MANUAL // user applied or overrode the category directly
}

enum AnomalyType {
  LARGE_OUTFLOW                  // a single transaction >3x the trailing average
  NEW_COUNTERPARTY_LARGE_PAYMENT // an unusually large FIRST payment to a new counterparty
}

enum AnomalyStatus {
  OPEN
  DISMISSED
}

// ─────────────────────────────────────────────────────────────────────────
// CORE TABLES
// ─────────────────────────────────────────────────────────────────────────

model Organization {
  id                     String            @id @default(cuid())
  legalName              String
  username               String?           @unique
  defaultLedgerAccountId String?
  kybStatus              KybStatus         @default(PENDING)
  kybApprovedAt          DateTime?
  kybApprovedBy          String? // admin user id, manual-approval stub

  // Circle references
  circleEntityId         String? // Circle-side entity/customer reference, if applicable

  users                  User[]
  wallets                Wallet[]
  ledgerAccounts         LedgerAccount[]
  contacts               Contact[]
  idempotencyKeys        IdempotencyKey[]
  invoices               Invoice[]
  paymentLinks           PaymentLink[]
  allocationRules        AllocationRule[]
  payees                 Payee[]
  payrollSchedules       PayrollSchedule[]
  payrollRuns            PayrollRun[]
  savingsRules           SavingsRule[]
  recurringTransfers     RecurringTransfer[]
  transactionCategories  TransactionCategory[]
  transactionCategorizations TransactionCategorization[]
  spendingAnomalies      SpendingAnomaly[]
  defaultLedgerAccount   LedgerAccount?    @relation("OrganizationDefaultLedgerAccount", fields: [defaultLedgerAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kybStatus])
  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  email         String    @unique
  passwordHash  String? // null if using magic-link only
  emailVerified DateTime?
  name          String?
  role          UserRole  @default(MEMBER)

  payrollRunsInitiated PayrollRun[] @relation("PayrollRunInitiator")
  payrollRunsApproved  PayrollRun[] @relation("PayrollRunApprover")
  recurringTransfersCreated RecurringTransfer[] @relation("RecurringTransferCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("users")
}

// Maps an Organization to its single Circle-custodied Arc wallet.
// One-to-one for now (an org has exactly one Wallet row); the schema
// allows one-to-many later (multiple onchain wallets per org) since
// orgId is not marked @unique.
model Wallet {
  id             String @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  circleWalletId String @unique // Circle's internal wallet id
  circleWalletSetId String? // Circle wallet set id, useful for key rotation/lookups
  arcAddress     String @unique // 0x... address on Arc
  chain          Chain  @default(ARC_TESTNET)

  ledgerAccounts   LedgerAccount[]
  onchainTxs       OnchainTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("wallets")
}

// Internal balance "buckets" (Operating / Tax / Payroll / Savings / custom).
// All backed by the SAME Wallet row — this is the multiple-balances abstraction.
model LedgerAccount {
  id                     String            @id @default(cuid())
  orgId                  String
  organization           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  walletId               String
  wallet                 Wallet            @relation(fields: [walletId], references: [id], onDelete: Restrict)

  name                   String
  type                   LedgerAccountType @default(CUSTOM)

  // ── Phase 7 — Smart Savings (yield) ─────────────────────────────────
  // A bucket's ledger balance (lib/ledger/engine.ts#getBalance) ALWAYS
  // represents only liquid, immediately-spendable USDC — that invariant
  // is unchanged by this phase. When isYieldEnabled is true, a slice of
  // every fresh inflow swept into this bucket is additionally deployed
  // into USYC (tracked in YieldPosition, valued separately) rather than
  // sitting idle. See lib/savings/sweep.ts and lib/savings/yield.ts.
  isYieldEnabled         Boolean           @default(false)
  // Basis points (0–10000) of a fresh sweep INTO this bucket that should
  // be deployed into USYC; the remainder stays liquid as an instant-
  // withdrawal buffer. Required (non-null) iff isYieldEnabled — enforced
  // in lib/savings/service.ts#setBucketYieldConfig (a DB CHECK can't
  // express "required iff sibling column is true" declaratively).
  yieldAllocationPct     Int?
  // Smallest USDC unit. Any sweep (savings or allocation) sourcing FROM
  // this bucket must never bring its liquid balance below this floor —
  // see lib/savings/sweep.ts#computeFloorConstrainedAmount. 0 (default)
  // preserves all pre-Phase-7 behavior (no floor).
  minimumBalanceFloor    BigInt            @default(0)

  entries                LedgerEntry[]
  defaultForOrgs         Organization[]    @relation("OrganizationDefaultLedgerAccount")
  paymentLinks           PaymentLink[]
  allocationRulesAsSource AllocationRule[] @relation("AllocationRuleSource")
  allocationRulesAsTarget AllocationRule[] @relation("AllocationRuleTarget")
  payrollSchedules        PayrollSchedule[]
  payrollRuns             PayrollRun[]
  savingsRulesAsSource    SavingsRule[]    @relation("SavingsRuleSource")
  savingsRulesAsTarget    SavingsRule[]    @relation("SavingsRuleTarget")
  yieldPositions          YieldPosition[]
  yieldRedemptionRequests YieldRedemptionRequest[]
  recurringTransfersAsSource      RecurringTransfer[] @relation("RecurringTransferSource")
  recurringTransfersAsDestination RecurringTransfer[] @relation("RecurringTransferDestination")
  archived               Boolean           @default(false)
  archivedAt             DateTime?
  archivedBy             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
  @@index([orgId, archived])
  @@index([walletId])
  @@map("ledger_accounts")
}

// APPEND-ONLY. Never update or delete rows — corrections are new
// offsetting entries. Sum of entries for an org must always equal
// the sum across its LedgerAccounts and reconcile against the
// actual onchain wallet balance.
//
// Phase 7 note: this invariant is specifically about USDC custody. Once
// a bucket deploys funds into USYC (a different token held in the same
// Circle wallet), that value leaves this reconciliation's scope by
// design — LedgerEntry/getBalance stays USDC-only, and YieldPosition is
// the parallel ledger for deployed value. See lib/savings/overview.ts
// for the composed liquid+deployed view.
model LedgerEntry {
  id              String @id @default(cuid())
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)

  // Stored as bigint in smallest USDC unit (6 decimals). Never use float.
  amount        BigInt
  direction     LedgerDirection
  referenceType LedgerReferenceType
  referenceId   String // polymorphic FK — id of the Invoice/PayrollRun/OnchainTransaction/etc that created this entry

  // Denormalized snapshot of the ledger account's balance immediately
  // after this entry, for fast reads without summing full history.
  balanceAfter BigInt

  createdAt DateTime @default(now())

  @@index([ledgerAccountId, createdAt])
  @@index([referenceType, referenceId])
  @@map("ledger_entries")
}

model OnchainTransaction {
  id                  String @id @default(cuid())
  walletId            String
  wallet              Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  txHash              String? @unique // null until broadcast/confirmed
  direction           OnchainDirection
  amount              BigInt // smallest USDC unit
  counterpartyAddress String
  chain               Chain
  sourceChain         Chain?
  status              OnchainTxStatus @default(PENDING)

  circleTransactionId String? @unique
  idempotencyKey      String? @unique
  rawPayload          Json?
  memo                String?
  referenceType       LedgerReferenceType?
  referenceId         String?

  // Back-reference for Invoice.paidTxId — set when this inbound tx was
  // auto-reconciled against an invoice (see lib/invoices/reconciliation.ts).
  paidInvoice         Invoice?

  // Back-reference for PaymentLinkPayment.txId — set once this tx has been
  // matched to a payment-link checkout session (see
  // lib/paymentLinks/reconciliation.ts). Either side of a refund pair
  // (the original inbound IN and the refund OUT) may point back here.
  paymentLinkPayment  PaymentLinkPayment?

  // Back-reference for PayrollRunItem.txId — set when this outbound tx
  // is a payroll disbursement (see lib/payroll/execution.ts). @unique —
  // a given onchain transaction settles at most one payroll run item.
  payrollRunItem      PayrollRunItem?

  // Back-reference for RecurringTransferExecution.txId — set when this
  // outbound tx is an external-facing DCA execution (see
  // lib/dca/execution.ts). @unique — a given onchain transaction settles
  // at most one recurring-transfer execution. Never set for the internal
  // bucket-to-bucket DCA path, which never creates an OnchainTransaction
  // at all (see RecurringTransfer.destinationLedgerAccountId).
  recurringTransferExecution RecurringTransferExecution?

  // Phase 9 — Spending Insights. @unique: a transaction has at most one
  // active categorization (see TransactionCategorization). One-to-many
  // for anomalies since the SAME transaction can independently trip both
  // AnomalyType checks (e.g. a large payment that's ALSO a new
  // counterparty's first payment).
  categorization TransactionCategorization?
  anomalies      SpendingAnomaly[]

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([walletId, status])
  @@index([circleTransactionId])
  @@map("onchain_transactions")
}

// Raw storage of every inbound Circle webhook BEFORE processing,
// so a bug in handler logic can never lose an event.
model WebhookEvent {
  id            String @id @default(cuid())
  source        String @default("circle")
  eventType     String?
  signatureOk   Boolean @default(false)
  rawPayload    Json
  status        WebhookEventStatus @default(RECEIVED)
  processError  String?

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status])
  @@index([eventType])
  @@map("webhook_events")
}

model Contact {
  id             String         @id @default(cuid())
  orgId          String
  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  displayName    String
  identifier     String
  identifierType IdentifierType
  notes          String?
  lastPaidAt     DateTime?

  // A Payee may optionally link back to this Contact to avoid duplicate
  // data entry — see Payee.contactId. Not unique: nothing stops two
  // Payee rows (e.g. a stale/duplicate one) from pointing at the same
  // Contact, though the UI shouldn't normally create that.
  payees Payee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, identifier])
  @@index([orgId, lastPaidAt])
  @@map("contacts")
}

model IdempotencyKey {
  id             String                @id @default(cuid())
  orgId          String
  organization   Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endpoint       String
  key            String
  requestHash    String
  status         IdempotencyKeyStatus @default(PENDING)
  responseBody   Json?
  responseStatus Int?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, endpoint, key])
  @@index([orgId])
  @@map("idempotency_keys")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 3 — INVOICING
// ─────────────────────────────────────────────────────────────────────────

// An invoice issued BY orgId, to be paid by recipientIdentifier (who may
// or may not be a Comparta org — invoices can go to plain emails/addresses
// outside the platform). All money fields are bigint smallest-unit, computed
// server-side from lineItems — never trust a client-submitted total.
model Invoice {
  id           String @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Who owes this invoice. Not a FK to Organization/User — invoices can
  // target a username, a raw Arc address, or a bare email for someone
  // with no Comparta account at all. Resolved (if possible) only at
  // send-time for in-app notification purposes; never required to resolve.
  recipientIdentifier String
  recipientEmail      String? // required to actually deliver the "sent" email if recipientIdentifier isn't itself an email

  // [{ description: string, quantity: string, unitPrice: string (decimal),
  //    lineTotal: string (decimal) }] — quantity/unitPrice/lineTotal are
  // stored as decimal strings for display; subtotal/total below are the
  // authoritative bigint smallest-unit values computed from this array.
  lineItems Json

  subtotal  BigInt
  taxAmount BigInt @default(0)
  total     BigInt

  currency InvoiceCurrency @default(USDC)
  status   InvoiceStatus   @default(DRAFT)

  dueDate DateTime

  // Phase 4: every invoice gets a single-use, amount-locked PaymentLink at
  // creation time (see lib/paymentLinks/service.ts#createPaymentLinkForInvoice,
  // called from lib/invoices/service.ts#createInvoice). @unique because the
  // relationship is 1:1 — an invoice-linked PaymentLink is never shared
  // across invoices. Nullable/SetNull so a failed link-creation attempt (or
  // a link created before this relation existed) never blocks invoice
  // reads/writes — the public invoice page falls back to the direct-address
  // flow when this is null (see lib/invoices/service.ts#getPublicInvoice).
  paymentLinkId String? @unique
  paymentLink   PaymentLink? @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)

  // Set by auto-reconciliation (lib/invoices/reconciliation.ts, or
  // lib/paymentLinks/completion.ts when paid via this invoice's payment
  // link) once a matching inbound transfer confirms. @unique: an
  // OnchainTransaction can settle at most one invoice.
  paidTxId String?             @unique
  paidTx   OnchainTransaction? @relation(fields: [paidTxId], references: [id], onDelete: SetNull)

  // Overdue-reminder rate limiting (see jobs/invoiceOverdue.worker.ts):
  // reminders fire at dueDate, dueDate+3d, dueDate+7d, then stop.
  // reminderCount is how many of those 3 milestones have fired so far.
  reminderCount  Int       @default(0)
  lastReminderAt DateTime?

  events InvoiceEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sentAt    DateTime?
  paidAt    DateTime?

  @@index([orgId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

// Append-only audit trail for an invoice — powers both the issuer-facing
// status timeline ("viewed 2 days ago") and dispute resolution. Never
// update or delete rows; corrections are new events.
model InvoiceEvent {
  id        String @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  eventType InvoiceEventType
  metadata  Json? // e.g. { onchainTransactionId } for PAID, { milestoneDays } for REMINDER_SENT

  createdAt DateTime @default(now())

  @@index([invoiceId, createdAt])
  @@map("invoice_events")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 4 — PAYMENT LINKS
// ─────────────────────────────────────────────────────────────────────────

// A standalone shareable checkout URL (/pay/[slug]), usable on its own
// ("pay me $50 for consulting") or attached 1:1 to an Invoice (see
// Invoice.paymentLinkId). Never mutate amount/type after creation for a
// link that already has a CONFIRMED payment — create a new link instead;
// this table has no versioning story and callers shouldn't need one.
model PaymentLink {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Short, collision-resistant, URL-safe. Generated server-side (see
  // lib/paymentLinks/slug.ts) — never client-supplied, so there's no
  // user-facing "this slug is taken" flow to design around.
  slug String @unique

  type        PaymentLinkType
  amount      BigInt? // smallest USDC unit; must be set iff type = FIXED_AMOUNT
  description String?

  status    PaymentLinkStatus @default(ACTIVE)
  expiresAt DateTime?
  maxUses   Int? // null = unlimited
  useCount  Int  @default(0)

  // Which internal balance bucket a successful payment credits. Must
  // belong to the same org (enforced in lib/paymentLinks/service.ts).
  receivingLedgerAccountId String
  receivingLedgerAccount   LedgerAccount @relation(fields: [receivingLedgerAccountId], references: [id], onDelete: Restrict)

  payments PaymentLinkPayment[]
  invoice  Invoice? // back-reference: at most one invoice may attach to this link

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([status, expiresAt])
  @@map("payment_links")
}

// One row per checkout attempt (not per successful payment — an abandoned
// or wrong-amount attempt still gets a row, so the merchant's usage list
// is a truthful log rather than only-happy-path). This is also the
// correlation anchor that lets an inbound onchain transfer or a Circle
// Payments API webhook be matched back to *this specific* checkout
// without guessing — see lib/paymentLinks/reconciliation.ts (wallet path)
// and lib/paymentLinks/checkout.ts (card path, matched by circlePaymentId).
model PaymentLinkPayment {
  id            String @id @default(cuid())
  paymentLinkId String
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Restrict)

  // Anonymous/external payer identifier — email (card path) or the
  // sending wallet address (wallet path, filled in once observed).
  // Nullable: a payer may never be identified at all.
  payerIdentifier String?
  method          PaymentMethod

  // Amount this session expects to receive, in smallest USDC unit — set
  // at session-start time (equal to PaymentLink.amount for FIXED_AMOUNT
  // links, or payer-entered and validated for OPEN_AMOUNT links). This is
  // the value inbound-transfer matching compares against, NOT a
  // post-hoc record of what arrived.
  amountExpected BigInt

  // What was actually credited, if anything. Differs from amountExpected
  // only in the WRONG_AMOUNT_REFUNDED case.
  amountPaid BigInt?

  status PaymentLinkPaymentStatus @default(PENDING)

  // Set once a matching inbound OnchainTransaction is found (wallet path)
  // or once Circle's USDC settlement transaction lands (card path, after
  // conversion). @unique — a given onchain transaction settles at most
  // one checkout attempt.
  txId String? @unique
  tx   OnchainTransaction? @relation(fields: [txId], references: [id], onDelete: SetNull)

  // Card/ACH path only: Circle Payments API's payment id, echoed back on
  // its webhook, and our own idempotency key sent on creation. Because we
  // control both ends of this API call, this path never needs the
  // amount-matching heuristic the wallet path relies on.
  circlePaymentId String? @unique
  idempotencyKey  String? @unique

  failureReason String?

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([paymentLinkId, status])
  @@index([status, createdAt])
  @@map("payment_link_payments")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE — BUCKET MANAGEMENT & ALLOCATION RULES
// ─────────────────────────────────────────────────────────────────────────

// A standing rule: "whenever <sourceLedgerAccount> receives money via
// <trigger>, move <value> to <targetLedgerAccount>." Created/edited only by
// OWNER/ADMIN — see lib/auth/canManageBucket.ts. Executed by
// lib/allocationRules/engine.ts.
model AllocationRule {
  id    String       @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sourceLedgerAccountId String
  sourceLedgerAccount   LedgerAccount @relation("AllocationRuleSource", fields: [sourceLedgerAccountId], references: [id], onDelete: Restrict)

  targetLedgerAccountId String
  targetLedgerAccount   LedgerAccount @relation("AllocationRuleTarget", fields: [targetLedgerAccountId], references: [id], onDelete: Restrict)

  // Optional human label shown in the UI, e.g. "20% to Tax Reserve".
  // Auto-generated from ruleType/value/target if not supplied — see
  // lib/allocationRules/service.ts#describeRule.
  name String?

  ruleType AllocationRuleType

  // PERCENTAGE: basis points, 1–10000 (10000 = 100.00%). Never a float.
  // FIXED_AMOUNT: smallest USDC unit (6 decimals), same convention as
  // every other money column in this schema.
  value BigInt

  trigger AllocationTrigger @default(ON_INCOMING_PAYMENT)

  // SCHEDULED rules only. Standard 5-field cron string, evaluated in UTC
  // by jobs/workers/allocationRulesScheduled.worker.ts. Null for
  // ON_INCOMING_PAYMENT rules.
  scheduleCron String?

  // Execution order when a source account has multiple active rules —
  // lower runs first. Matters for FIXED_AMOUNT rules, since an earlier
  // rule's transfer reduces the balance available to a later one.
  priority Int @default(0)

  active         Boolean   @default(true)
  lastExecutedAt DateTime?

  executions AllocationRuleExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Enforced in application code, not the DB: for a given
  // (orgId, sourceLedgerAccountId, trigger), the sum of `value` across all
  // active PERCENTAGE rules must never exceed 10000 basis points. See
  // lib/allocationRules/service.ts#assertPercentageBudget. A DB-level
  // CHECK can't express a cross-row SUM constraint, so this must stay a
  // service-layer invariant — every write path (create + update) goes
  // through that one function.
  @@index([orgId, sourceLedgerAccountId, trigger, active])
  @@index([trigger, active])
  @@map("allocation_rules")
}

// APPEND-ONLY audit log, one row per attempted trigger firing — including
// skipped (rounds to zero) and failed (insufficient balance) attempts, so
// "why didn't my rule fire" is always answerable from the DB. Mirrors
// InvoiceEvent / LedgerEntry's append-only convention elsewhere in this
// schema. Never update or delete rows.
model AllocationRuleExecution {
  id               String         @id @default(cuid())
  allocationRuleId String
  allocationRule   AllocationRule @relation(fields: [allocationRuleId], references: [id], onDelete: Cascade)

  // What inbound event caused this rule to be evaluated, e.g.
  // referenceType=ONCHAIN_TX, referenceId=<the OnchainTransaction.id>
  // that credited the source bucket. For SCHEDULED rules this instead
  // references the sweep job run (see jobs/workers/allocationRulesScheduled.worker.ts).
  triggerReferenceType LedgerReferenceType
  triggerReferenceId   String

  amountAllocated BigInt // 0 for SKIPPED_ZERO_AMOUNT / FAILED
  status          AllocationExecutionStatus

  // Set only when status = EXECUTED — the referenceId shared by the two
  // LedgerEntry rows (debit + credit) this execution created, so a
  // support engineer can go straight from this row to the exact ledger
  // movement it caused via LedgerEntry.referenceType/referenceId.
  ledgerReferenceId String?

  errorMessage String? // set only when status = FAILED

  createdAt DateTime @default(now())

  @@index([allocationRuleId, createdAt])
  @@index([status])
  @@map("allocation_rule_executions")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 6 — PAYROLL
// ─────────────────────────────────────────────────────────────────────────

// A formal payroll relationship — distinct from Contact (the general
// address book). A Payee may optionally point at a Contact to reuse an
// already-saved identifier, but Payee is never derived data: it carries
// payroll-specific fields (pay type, default amount) that don't belong
// on the address book. See lib/payroll/payees.ts.
model Payee {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name String

  // Username or Arc address — same format/validation convention as
  // Contact.identifier (lib/payroll/payees.ts mirrors the normalization
  // in lib/contacts/service.ts). Resolvability against this identifier
  // is (re-)checked every time a payroll run is generated, NOT just
  // once at Payee creation — a username can be transferred/deactivated
  // after this row is created.
  identifier String
  identifierType IdentifierType
  payType    PayType @default(CONTRACT)

  // Smallest USDC unit. Null for payees whose amount varies per run
  // (e.g. many HOURLY workers) — a run built for such a payee must have
  // its item amount supplied explicitly (manual run creation, or an
  // edit to a DRAFT run before submitting for approval). Auto-generation
  // from a schedule (lib/payroll/scheduler.ts) skips any active payee
  // with no defaultAmount and logs it, rather than guessing an amount.
  defaultAmount BigInt?

  notes  String?
  active Boolean @default(true)

  // Optional link to an existing Contact row purely to avoid re-entering
  // an identifier that's already in the address book. Never required —
  // onDelete: SetNull so deleting the Contact never cascades into
  // deleting payroll history.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  runItems PayrollRunItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, identifier])
  @@index([orgId, active])
  @@map("payees")
}

// A standing instruction: "every <frequency>, build a draft payroll run
// from <sourceLedgerAccountId>'s active Payees." Never executes money on
// its own — it only ever produces a DRAFT PayrollRun (see
// lib/payroll/scheduler.ts), which still needs a full human approval
// before a cent moves. Created/edited only by OWNER/ADMIN, same gate as
// buckets/allocation rules — see lib/auth/canManageBucket.ts.
model PayrollSchedule {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sourceLedgerAccountId String
  sourceLedgerAccount   LedgerAccount @relation(fields: [sourceLedgerAccountId], references: [id], onDelete: Restrict)

  name      String? // optional human label, e.g. "Biweekly payroll"
  frequency PayrollFrequency

  // The next date this schedule is due to auto-generate a DRAFT run.
  // Advanced by lib/payroll/scheduler.ts AFTER a run is successfully
  // generated for this date — never advanced speculatively — so a
  // worker crash between generating the run and advancing this field
  // just means the next sweep re-evaluates the same date (harmless: run
  // generation itself is deduped by PayrollRun's
  // (payrollScheduleId, scheduledFor) unique constraint).
  nextRunDate DateTime
  active      Boolean  @default(true)

  runs PayrollRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, active])
  @@index([active, nextRunDate])
  @@map("payroll_schedules")
}

// One payroll batch. DRAFT (auto-generated or built manually) ->
// PENDING_APPROVAL (submitted for review) -> PROCESSING (approved,
// execution under way) -> COMPLETED (every item reached a terminal
// state) or FAILED (the run could not even begin executing — see
// lib/payroll/execution.ts). Individual payee failures during execution
// do NOT move the run to FAILED; they're tracked per-item on
// PayrollRunItem so one bad payee never blocks or misrepresents the
// rest of the run.
model PayrollRun {
  id                String           @id @default(cuid())
  payrollScheduleId String?
  payrollSchedule   PayrollSchedule? @relation(fields: [payrollScheduleId], references: [id], onDelete: SetNull)

  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Always set, even for schedule-generated runs (copied from
  // PayrollSchedule.sourceLedgerAccountId at generation time). Kept as
  // its own column rather than only reachable via payrollSchedule
  // because payrollScheduleId is nullable (manual one-off runs) — a run
  // must always know its funding source directly, without an optional
  // hop through a possibly-absent schedule.
  sourceLedgerAccountId String
  sourceLedgerAccount   LedgerAccount @relation(fields: [sourceLedgerAccountId], references: [id], onDelete: Restrict)

  // The schedule's nextRunDate at the moment this run was auto-generated.
  // This is the double-trigger guard (see @@unique below and
  // lib/payroll/scheduler.ts): if the daily sweep somehow fires twice for
  // the same due date (e.g. an overlapping cron invocation, a retried
  // job), the second attempt hits a unique-constraint violation instead
  // of creating a duplicate run. Null for manually-created one-off runs,
  // which have no period to dedupe against.
  scheduledFor DateTime?

  status      PayrollRunStatus @default(DRAFT)
  // Sum of item amounts, smallest USDC unit. Recomputed by
  // lib/payroll/runs.ts on every item add/remove/amount-edit while the
  // run is still DRAFT — never trust a client-submitted total.
  totalAmount BigInt           @default(0)

  // Nullable: auto-generated runs have no human initiator (see
  // lib/payroll/scheduler.ts). Manual runs always set this to the
  // creating user.
  initiatedBy String?
  initiator   User?   @relation("PayrollRunInitiator", fields: [initiatedBy], references: [id], onDelete: SetNull)

  // Required to be set together with the PENDING_APPROVAL -> PROCESSING
  // transition — see lib/payroll/runs.ts#approveRun. Enforced in
  // application code (an OWNER/ADMIN via canManageBucket), not the DB.
  approvedBy String?
  approver   User?     @relation("PayrollRunApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvedAt DateTime?

  items PayrollRunItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@unique([payrollScheduleId, scheduledFor])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("payroll_runs")
}

// One payee's line item within a PayrollRun. PENDING (not yet attempted)
// -> SENT (sendPayment succeeded, tx submitted and PENDING onchain) ->
// CONFIRMED (onchain tx confirmed) or FAILED (either sendPayment itself
// failed — bad identifier, provider error, mid-run balance race — or the
// onchain tx subsequently failed and was reversed; see
// lib/payroll/completion.ts). FAILED items are the manual-retry unit —
// see lib/payroll/execution.ts#retryPayrollRunItem.
model PayrollRunItem {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  payeeId String
  payee   Payee  @relation(fields: [payeeId], references: [id], onDelete: Restrict)

  amount BigInt // smallest USDC unit
  status PayrollRunItemStatus @default(PENDING)

  // Set once sendPayment() has submitted this item (status becomes
  // SENT). @unique — a given onchain transaction settles at most one
  // payroll run item. Cleared (set back to null) on manual retry so a
  // fresh attempt gets its own OnchainTransaction row rather than
  // reusing a failed one.
  txId String?             @unique
  tx   OnchainTransaction? @relation(fields: [txId], references: [id], onDelete: SetNull)

  // True when this item's payee identifier failed to resolve at
  // run-creation (or regeneration) time — the "flag at run-creation,
  // not execution" edge case. A run with any identifierIssue item is
  // blocked from approval until the item is fixed (payee identifier
  // corrected and the run regenerated/edited) or removed from the run.
  // Distinct from a runtime send/onchain failure, which is a normal
  // FAILED status with no identifierIssue flag.
  identifierIssue Boolean @default(false)

  // User-facing reason for a FAILED status (send-time error, onchain
  // failure, or — combined with identifierIssue — an unresolved
  // recipient identifier).
  failureReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sentAt      DateTime?
  confirmedAt DateTime?

  @@index([payrollRunId, status])
  @@index([payeeId])
  @@map("payroll_run_items")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 7 — SMART SAVINGS (YIELD)
// ─────────────────────────────────────────────────────────────────────────

// One deployment of a bucket's liquid USDC into USYC. Deploying DEBITs the
// bucket's LedgerAccount (referenceType YIELD_DEPLOYMENT — see
// lib/savings/yield.ts#deployToYield): LedgerAccount balance
// (lib/ledger/engine.ts#getBalance) reflects ONLY spendable/liquid USDC,
// same as every other bucket in this codebase. The value held in USYC
// lives here instead, and is added back for display purposes by
// lib/savings/overview.ts#getSavingsBucketOverview.
//
// Partial redemption is supported by reducing usycAmount on this SAME
// row (never below 0) rather than requiring a fresh row per partial
// redemption — the row is only marked REDEEMED once it reaches exactly
// zero. See YieldRedemptionRequest for the per-attempt audit trail.
model YieldPosition {
  id              String @id @default(cuid())
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)

  // Smallest USYC unit — this codebase assumes USYC exposes the same
  // 6-decimal convention as USDC (see lib/circle/amount.ts); adjust
  // USDC_DECIMALS-equivalent scaling in lib/savings/yield.ts if Circle's
  // USYC integration uses a different decimal count. Reduced (never
  // below 0) on each partial redemption.
  usycAmount BigInt

  // Smallest USDC unit — the amount of USDC that was converted into
  // usycAmount at deploy time (this position's cost basis). Never
  // recomputed after deploy; accrued yield is always (current USYC
  // value at today's NAV) minus this basis, computed on read in
  // lib/savings/overview.ts, never stored, so it can never go stale.
  usdcEquivalentAtDeploy BigInt

  // NAV (USDC per whole USYC token) at the moment of deployment, decimal
  // string (e.g. "1.05123456"). USYC accrues via NAV APPRECIATION, not by
  // minting more tokens — this is the reference point every later
  // valuation and partial-redemption settlement is measured against.
  navAtDeploy String

  status     YieldPositionStatus @default(ACTIVE)
  deployedAt DateTime @default(now())
  redeemedAt DateTime?

  redemptionRequests YieldRedemptionRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ledgerAccountId, status])
  @@map("yield_positions")
}

// One redemption ATTEMPT (full or partial) against a single YieldPosition.
// APPEND-ONLY, one row per attempt — mirrors PaymentLinkPayment's "one
// row per attempt, not per success" convention, so an attempt that fails
// or is still settling is a truthful row rather than silently discarded.
//
// This row is also the async state machine the UI polls:
// "near-instant" USYC redemption is still always modeled as
// PENDING -> PROCESSING -> COMPLETED/FAILED, never assumed synchronous —
// see lib/savings/yield.ts and jobs/confirmYieldRedemption.ts.
model YieldRedemptionRequest {
  id              String @id @default(cuid())
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)

  yieldPositionId String
  yieldPosition   YieldPosition @relation(fields: [yieldPositionId], references: [id], onDelete: Restrict)

  // Smallest USYC unit requested for redemption from this position.
  usycAmountRequested BigInt

  // Filled in once Circle reports settlement — the actual USDC credited.
  // May differ from a naive usycAmountRequested * navAtDeploy estimate,
  // since the NAV applied is the NAV AT REDEMPTION, not at deploy.
  usdcAmountSettled BigInt?

  status YieldRedemptionStatus @default(PENDING)

  // Circle's USYC conversion/order id, echoed back on status polls — same
  // idempotency posture as OnchainTransaction.circleTransactionId.
  circleConversionId String? @unique
  idempotencyKey     String? @unique

  // Set once settlement lands and the bucket's LedgerAccount has been
  // credited (referenceType YIELD_REDEMPTION, referenceId = this row's id).
  ledgerEntryId String?

  failureReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  settledAt DateTime?

  @@index([ledgerAccountId, status])
  @@index([yieldPositionId])
  @@map("yield_redemption_requests")
}

// A standing instruction that sweeps money INTO a yield-enabled savings
// bucket. Mirrors AllocationRule's shape closely (see
// lib/allocationRules/engine.ts) but with a third trigger, ROUND_UP, that
// AllocationRule has no equivalent for — see lib/savings/sweep.ts for why
// ROUND_UP has to hook outbound payments rather than inbound ones.
model SavingsRule {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name String?

  trigger SavingsRuleTrigger

  // PERCENTAGE_OF_INCOME: basis points, 1–10000, of every inbound payment
  //   credited to sourceLedgerAccountId.
  // ROUND_UP: the round-up unit, smallest USDC unit (e.g. 10_000000 =
  //   round up to the nearest $10). Every OUTBOUND payment debited from
  //   sourceLedgerAccountId is rounded up to the next multiple of this
  //   value; the difference is swept to targetLedgerAccountId.
  // FIXED_RECURRING: smallest USDC unit swept on scheduleCron's cadence,
  //   regardless of payment activity.
  value BigInt

  // FIXED_RECURRING only — standard 5-field cron, evaluated in UTC by
  // jobs/workers/savingsSweep.worker.ts, same day-granularity caveat as
  // AllocationRule.scheduleCron (see lib/allocationRules/engine.ts).
  scheduleCron   String?
  lastExecutedAt DateTime?

  sourceLedgerAccountId String
  sourceLedgerAccount   LedgerAccount @relation("SavingsRuleSource", fields: [sourceLedgerAccountId], references: [id], onDelete: Restrict)

  // Must have isYieldEnabled = true — enforced in
  // lib/savings/service.ts#createSavingsRule, not at the DB level (a
  // schema-level CHECK can't reach across to another row's boolean).
  targetLedgerAccountId String
  targetLedgerAccount   LedgerAccount @relation("SavingsRuleTarget", fields: [targetLedgerAccountId], references: [id], onDelete: Restrict)

  active Boolean @default(true)

  executions SavingsRuleExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, sourceLedgerAccountId, trigger, active])
  @@index([trigger, active])
  @@map("savings_rules")
}

// APPEND-ONLY audit log, one row per attempted trigger firing — including
// skipped (zero amount, or blocked by the source bucket's minimum-floor
// protection) and failed attempts. Mirrors AllocationRuleExecution.
model SavingsRuleExecution {
  id            String @id @default(cuid())
  savingsRuleId String
  savingsRule   SavingsRule @relation(fields: [savingsRuleId], references: [id], onDelete: Cascade)

  triggerReferenceType LedgerReferenceType
  triggerReferenceId   String

  amountSwept BigInt // 0 for SKIPPED_* / FAILED
  status      SavingsRuleExecutionStatus

  // Set only when status = EXECUTED — the referenceId shared by the
  // sweep's debit+credit LedgerEntry pair, so a support engineer can go
  // straight from this row to the exact ledger movement it caused.
  ledgerReferenceId String?
  // Set only when the swept-in funds also triggered a USYC deployment.
  yieldPositionId   String?

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([savingsRuleId, createdAt])
  @@index([status])
  @@map("savings_rule_executions")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 8 — DCA / RECURRING TRANSFERS
// ─────────────────────────────────────────────────────────────────────────

// A standing instruction: "every <frequency>, send <amount> from
// <sourceLedgerAccountId> to <destination>." Distinct from AllocationRule
// / SavingsRule in two ways: it's purely TIME-interval-based (no payment-
// event trigger at all), and its destination is flexible — an external
// wallet, another Comparta org's username, or another bucket this same
// org owns.
//
// Destination is a discriminated union — EXACTLY ONE of
// destinationIdentifier / destinationLedgerAccountId is set, enforced in
// lib/dca/service.ts#createRecurringTransfer (a DB CHECK can't express
// "exactly one of these two columns is non-null" portably):
//   - destinationIdentifier: a Comparta username or raw Arc address,
//     resolved via lib/identity/resolver.ts — the SAME resolver
//     lib/transfers/send.ts#sendPayment uses. Re-resolved FRESH at every
//     single execution (see lib/dca/execution.ts) — NEVER cached here,
//     because a username can be released, transferred, or repointed
//     between setup and any given execution, and each cycle must send to
//     whoever/whatever the identifier currently points to (or fail
//     loudly if it no longer resolves).
//   - destinationLedgerAccountId: another bucket THIS SAME ORG owns
//     (e.g. "5% of Operating to Savings every week"). Moved via
//     lib/ledger/engine.ts#transferBetweenLedgerAccounts with NO onchain
//     transaction at all — sendPayment() itself rejects same-org sends,
//     and an onchain hop between two buckets backed by the same wallet
//     would be pointless. This is why this path is modeled as its own
//     column rather than relying on destinationIdentifier resolving to
//     "your own org" (which tells you WHICH org, not WHICH bucket).
model RecurringTransfer {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sourceLedgerAccountId String
  sourceLedgerAccount   LedgerAccount @relation("RecurringTransferSource", fields: [sourceLedgerAccountId], references: [id], onDelete: Restrict)

  destinationIdentifier      String? // Comparta username or raw Arc address — see header comment
  destinationLedgerAccountId String?
  destinationLedgerAccount   LedgerAccount? @relation("RecurringTransferDestination", fields: [destinationLedgerAccountId], references: [id], onDelete: Restrict)

  // Smallest USDC unit. Fixed every cycle — v1 has no "percentage of
  // current balance" DCA mode (that's what Phase 7's SavingsRule /
  // AllocationRule are for); this is deliberately just "the same dollar
  // amount, every time."
  amount    BigInt
  frequency RecurringTransferFrequency

  // UTC always — see lib/dca/schedule.ts#computeNextExecutionDate. The
  // API layer is responsible for converting any user-local input to UTC
  // before this is set; nothing in this schema or lib/dca/* ever
  // interprets this in any other timezone.
  nextExecutionDate DateTime
  // null = run forever. Once advancing nextExecutionDate would land past
  // endDate, the sweep marks this COMPLETED instead of scheduling
  // another cycle — see jobs/processRecurringTransfers.ts.
  endDate DateTime?

  status RecurringTransferStatus @default(ACTIVE)

  name String? // optional human label, e.g. "Weekly payout to my personal wallet"

  createdBy String
  creator   User @relation("RecurringTransferCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  executions RecurringTransferExecution[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cancelledAt DateTime?

  @@index([orgId, status])
  @@index([status, nextExecutionDate])
  @@map("recurring_transfers")
}

// APPEND-ONLY, one row per scheduled cycle — including failed and
// insufficient-funds cycles, so "why didn't this send" is always
// answerable from the DB, same posture as every other execution-log
// model in this schema (AllocationRuleExecution, SavingsRuleExecution,
// PayrollRunItem). Never update an existing row to represent a NEW
// cycle — jobs/processRecurringTransfers.ts creates a fresh row per
// scheduledDate.
model RecurringTransferExecution {
  id                  String @id @default(cuid())
  recurringTransferId String
  recurringTransfer   RecurringTransfer @relation(fields: [recurringTransferId], references: [id], onDelete: Cascade)

  // The nextExecutionDate this attempt was for — captured at the moment
  // of attempt, not recomputed later, so this row stays a truthful
  // record of which cycle it was even after the parent's
  // nextExecutionDate has since advanced.
  scheduledDate DateTime
  executedAt    DateTime?

  status RecurringTransferExecutionStatus @default(PENDING)

  // External-facing path only (destinationIdentifier) — set once
  // sendPayment() submits successfully. @unique — a given onchain
  // transaction settles at most one recurring-transfer execution. Null
  // for the internal bucket-to-bucket path (see ledgerReferenceId
  // below instead) and null while PENDING/on failure.
  txId String?             @unique
  tx   OnchainTransaction? @relation(fields: [txId], references: [id], onDelete: SetNull)

  // Internal bucket-to-bucket path only (destinationLedgerAccountId) —
  // the referenceId shared by the debit+credit LedgerEntry pair
  // transferBetweenLedgerAccounts() created for this cycle, so a support
  // engineer can trace this row straight to the exact ledger movement.
  ledgerReferenceId String?

  // Set on FAILED_INSUFFICIENT_FUNDS or FAILED_OTHER — e.g. "Source
  // bucket balance is below the scheduled amount" or "Recipient
  // '$oldusername' could not be resolved: username not found."
  failureReason String?

  createdAt DateTime @default(now())

  @@index([recurringTransferId, createdAt])
  @@index([status])
  @@map("recurring_transfer_executions")
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 9 — SPENDING INSIGHTS
// ─────────────────────────────────────────────────────────────────────────

// A curated (SYSTEM, seeded per-org by lib/insights/categorization/seed.ts
// — 7 fixed names: Payroll, Software/SaaS, Contractors, Taxes, Savings,
// Client Refunds, Other) or org-defined (CUSTOM) spend category. Every
// org gets its own row set rather than sharing global rows, so a SYSTEM
// category can never accidentally be renamed/archived out from under
// another org, and @@unique([orgId, name]) stays meaningful.
model TransactionCategory {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name String
  kind TransactionCategoryKind @default(CUSTOM)
  // CUSTOM categories can be archived (hidden from new-categorization
  // pickers, kept for historical rows); SYSTEM categories never should be
  // — enforced in lib/insights/categorization/service.ts, not the DB.
  archived Boolean @default(false)

  categorizations TransactionCategorization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@index([orgId, kind])
  @@map("transaction_categories")
}

// The applied category for one OnchainTransaction. @unique on
// onchainTransactionId: a transaction has exactly one CURRENT
// categorization at a time — re-categorizing (confirm/override) UPDATES
// this row rather than creating a new one, since (unlike
// AllocationRuleExecution-style audit logs elsewhere in this schema) the
// only thing worth keeping a history of here is the ORIGINAL LLM
// suggestion, which llmSuggestedCategoryName/llmReasoning preserve even
// after a user overrides it.
model TransactionCategorization {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  onchainTransactionId String             @unique
  onchainTransaction   OnchainTransaction @relation(fields: [onchainTransactionId], references: [id], onDelete: Cascade)

  categoryId String
  category   TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  source CategorizationSource

  // LLM-suggested confidence, basis points (10000 = 100%). Null for
  // RULE/MANUAL — those are never uncertain by construction.
  confidenceBps Int?

  // True while an LLM suggestion is below the confirmation threshold and
  // awaiting one-tap user confirm/override (see
  // lib/insights/categorization/service.ts#CONFIDENCE_THRESHOLD_BPS).
  // RULE and MANUAL rows are never pending. A high-confidence LLM
  // suggestion is auto-applied with this already false.
  needsConfirmation Boolean @default(false)
  confirmedAt       DateTime?

  // Preserved even after a MANUAL override replaces categoryId — lets you
  // audit/eval categorization quality later without re-calling the LLM.
  // Null for RULE-sourced rows (never called the LLM at all).
  llmSuggestedCategoryName String?
  llmReasoning             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, categoryId])
  @@index([orgId, needsConfirmation])
  @@map("transaction_categorizations")
}

// One flagged transaction. APPEND-only in spirit (never recomputed/
// mutated after creation except status), but naturally idempotent via
// @@unique([onchainTransactionId, type]) — the detection sweep upserts
// on that key so re-running it never creates duplicate flags for the
// same transaction+reason. "Worth a second look," never an accusation —
// `message` is written in that tone at creation time; nothing here
// blocks or reverses the underlying transaction in any way.
model SpendingAnomaly {
  id    String @id @default(cuid())
  orgId String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  onchainTransactionId String
  onchainTransaction   OnchainTransaction @relation(fields: [onchainTransactionId], references: [id], onDelete: Cascade)

  type   AnomalyType
  status AnomalyStatus @default(OPEN)

  // Pre-rendered, human-readable explanation — e.g. "This 12,000.00 USDC
  // payment to Acme Freight is about 5.2x your trailing 90-day average
  // outflow of 2,300.00 USDC — worth a second look." Written once at
  // creation so every consumer (dashboard, notification, API) shows the
  // exact same framing without re-deriving it.
  message String

  transactionAmount BigInt // smallest USDC unit — snapshot, same value as the source OnchainTransaction.amount
  comparisonAmount  BigInt? // the trailing average compared against; null when there wasn't enough history to compute one (e.g. a brand-new-counterparty flag with no prior average)
  multiplier        Float?  // transactionAmount / comparisonAmount; null when comparisonAmount is null

  createdAt   DateTime  @default(now())
  dismissedAt DateTime?

  @@unique([onchainTransactionId, type])
  @@index([orgId, status])
  @@map("spending_anomalies")
}
